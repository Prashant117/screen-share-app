{
  "name": "screen-share-app",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm --prefix screenShare-client install && npm --prefix screenShare-server install",
    "dev:client": "npm --prefix screenShare-client run dev",
    "dev:server": "npm --prefix screenShare-server run dev",
    "dev": "npm run dev:server & npm run dev:client",
    "build": "npm --prefix screenShare-client run build && npm --prefix screenShare-server run build",
    "lint": "npm --prefix screenShare-server run lint",
    "docs:pdf": "md-to-pdf README.md README.pdf --as-html --stylesheet https://cdnjs.cloudflare.com/ajax/libs/github-markdown-css/5.5.1/github-markdown.min.css --body-class markdown-body --highlight-style github"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "md-to-pdf": "^5.2.4",
    "typescript": "^5.2.2"
  }
}
